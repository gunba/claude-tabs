# Generated by proofd. Do not edit manually.
# Codex .rules files control command execution outside the sandbox.
# The proof documentation context remains in proofd and generated Markdown snapshots.

prefix_rule(
    pattern = [["python", "python3", "py"], "tools/proofd.py", ["status", "context", "entry-files", "select-matching", "lint", "review-brief"]],
    decision = "allow",
    justification = "Read-only proofd commands may inspect local rule context.",
    match = ["python tools/proofd.py status", "python3 tools/proofd.py context src/App.tsx"],
    not_match = ["python tools/proofd.py sync"],
)

prefix_rule(
    pattern = [["./tools/proofd.py", "tools/proofd.py"], ["status", "context", "entry-files", "select-matching", "lint", "review-brief"]],
    decision = "allow",
    justification = "Read-only proofd script invocations may inspect local rule context.",
    match = ["./tools/proofd.py status", "tools/proofd.py lint"],
    not_match = ["./tools/proofd.py add-entry --rule docs --statement x"],
)

prefix_rule(
    pattern = [["python", "python3", "py"], "tools/proofd.py", ["init", "import-legacy", "sync", "create-rule", "update-rule", "delete-rule", "allocate-tag", "add-entry", "update-entry", "delete-entry", "split-rule", "record-verification", "log-run", "promote-overlay", "mcp"]],
    decision = "prompt",
    justification = "Proofd mutation commands update generated snapshots or local proof state.",
    match = ["python tools/proofd.py sync", "python3 tools/proofd.py record-verification --tag AA-01 --status confirmed --files src/a.ts"],
)

prefix_rule(
    pattern = [["./tools/proofd.py", "tools/proofd.py"], ["init", "import-legacy", "sync", "create-rule", "update-rule", "delete-rule", "allocate-tag", "add-entry", "update-entry", "delete-entry", "split-rule", "record-verification", "log-run", "promote-overlay", "mcp"]],
    decision = "prompt",
    justification = "Proofd mutation script invocations update generated snapshots or local proof state.",
    match = ["./tools/proofd.py sync", "tools/proofd.py promote-overlay"],
)
