{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "python \"$(git rev-parse --show-toplevel)/tools/codex_hook.py\" session-start",
            "timeout": 30,
            "statusMessage": "Loading proofd guidance..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"$(git rev-parse --show-toplevel)/tools/codex_hook.py\" user-prompt-submit",
            "timeout": 30,
            "statusMessage": "Loading proofd context..."
          }
        ]
      }
    ]
  }
}
